{
  "name": "fixtureforge",
  "version": "0.1.0",
  "description": "Deterministic local-first file-tree fixtures for CLI tests.",
  "type": "module",
  "bin": {
    "fixtureforge": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true}); require('node:fs').rmSync('tmp',{recursive:true,force:true})\"",
    "check": "tsc --noEmit",
    "build": "tsc",
    "test": "npm run build && node --test dist/test/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run package:smoke"
  },
  "keywords": [
    "fixtures",
    "testing",
    "cli",
    "generator",
    "deterministic"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/fixtureforge.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/fixtureforge/issues"
  },
  "homepage": "https://github.com/rogerchappel/fixtureforge#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^24.10.1"
  }
}
